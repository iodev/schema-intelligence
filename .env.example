# PostgreSQL Connection
POSTGRES_URL=postgresql://user:password@localhost:5432/database

# MongoDB Connection
MONGODB_URL=mongodb://user:password@localhost:27017/database?authSource=admin

# Redis Connection
REDIS_URL=redis://localhost:6379

# InfluxDB Connection (with token and org as query params)
INFLUXDB_URL=http://localhost:8086?token=YOUR_TOKEN_HERE&org=your_org

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333

# Optional: Log Level
LOG_LEVEL=info
